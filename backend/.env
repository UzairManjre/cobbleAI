# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/cobbleai
DATABASE_NAME=cobbleai

# Redis (Caching & Celery Broker)
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Store
QDRANT_URL=http://localhost:6333

# Storage (MinIO locally, maps to AWS S3 in prod)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://localhost:9002
S3_BUCKET=cobble-documents

# Secret JWT Key for FastAPI-Users
SECRET_KEY=C0BBLE_AI_SUPER_SECRET_KEY_CHANGE_IN_PROD

# Local language Model
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:e2b

