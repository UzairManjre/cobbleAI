# ============================================================
# CobbleAI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in REAL values.
# NEVER commit .env to version control.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/cobbleai
DATABASE_NAME=cobbleai

# ── Redis (Cache + Celery Broker) ───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant (Vector Store) ───────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Object Storage (MinIO for dev, S3 for prod) ─────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://localhost:9002
S3_BUCKET=cobble-documents

# ── LLM (Ollama) ────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:e2b

# ── JWT (RS256) — CRITICAL SECURITY ─────────────────────────
# You MUST generate your own RSA key pair for production.
# The embedded keys below are for DEVELOPMENT ONLY.
#
# Generate a new key pair:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
#
# Then paste the contents here (escape newlines as \n).
# If you deploy with these default keys, the server WILL refuse to start.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_YOUR_OWN_PRIVATE_KEY\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_YOUR_OWN_PUBLIC_KEY\n-----END PUBLIC KEY-----"

# ── Optional: Super-secret fallback (only for local dev) ─────
# Used ONLY if JWT key files are not found. Change in prod.
SECRET_KEY=C0BBLE_AI_SUPER_SECRET_KEY_CHANGE_IN_PROD
